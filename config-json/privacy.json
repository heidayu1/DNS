{
  "name": "Privacy Combined",
  "description": "DNS block list that can be used for AdGuardHome. Source from https://filters.adtidy.org.",
  "homepage": "https://github.com/heidayu1/DNS",
  "license": "GPLv3",
  "version": "1.0.0.0",
  "sources": [
    {
      "name": "AdGuard Tracking Protection filter",
      "source": "https://filters.adtidy.org/extension/chromium/filters/3.txt",
      "type": "adblock",
      "inclusions": [
        "ad", "ads", "adserver", "adtima", "zalo", "zadn", "google", "doubleclick", "analytics", "gtm", "googletagmanager", "google-analytics", "app-measurement", 
          "firebase", "firebaselogging", "beacons", "gvt", "microsoft", "windows", "msn", "applicationinsights", "events", "activity", "apple", "icloud", 
          "xp.apple", "facebook", "instagram", "fbcdn", "graph", "appsflyer", "appsflyersdk", "applovin", "inmobi", "pangle", "mintegral", "adjust", "sentry", "branch", 
          "opera", "osp.opera", "samsung", "qq", "datadog", "cloudflare", "nel.cloudflare", ".vn", ".ru", "yandex", "mail.ru", "rambler", "vk.com", ".cn", "baidu", "alibaba", 
          "tencent", "zhihu", "feishu", "zh-live", "zh-", "live"
      ],
      "transformations": [
        "RemoveComments",
        "Compress",
        "Validate"
      ]
    }
  ],
  "transformations": [
    "RemoveComments",
    "Compress",
    "Validate",
    "Deduplicate",
    "TrimLines",
    "InsertFinalNewLine",
    "RemoveEmptyLines"
  ]
}
