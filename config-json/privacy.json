{
  "name": "Privacy Combined",
  "description": "DNS block list that can be used for AdGuardHome. Source from https://filters.adtidy.org.",
  "homepage": "https://github.com/heidayu1/DNS",
  "license": "GPLv3",
  "version": "1.0.0.0",
  "sources": [
    {
      "name": "AdGuard Tracking Protection filter",
      "source": "https://filters.adtidy.org/extension/chromium/filters/3.txt",
      "type": "adblock",
      "inclusions": [
        "ad", "adtima", "azure", "server", "za", "zalo", "zadn", "google", "doubleclick", "analytics", "gtm", 
        "app", "firebase", "firebaselogging", "beacons", "gvt", "microsoft", "windows", "msn", "applicationinsights", "events.data", 
        "activity.windows", "apple", "icloud", "xp.apple", "facebook", "instagram", "fbcdn", "graph", 
        "appsflyer", "appsflyersdk", "applovin", "inmobi", "pangle", "mintegral", "adjust", "sentry", 
        "branch", "opera", "osp.opera", "samsung", "qq", "datadog", "cloudflare", "nel.cloudflare", 
        ".vn", ".ru", "yandex", "mail.ru", "rambler", "vk.com", ".cn", "baidu", "alibaba", "tencent", 
        "zhihu", "feishu", "zh-live", "zh-", "live", "amazon" , "aws", "yahoo", "oppo", "unity", "miui", "huawei", 
        "shopee", "lazada", "tiki", "sendo", "momo", "zalopay", "vnpay", "mservice", "youtube", "tiktok", "cloud", "garena", "ip", "check", "api", "data", 
        "viettel", "fpt", "mobifone", "vnpt", "thegioididong", "tgdd", "bachhoaxanh", "bhx", "dienmayxanh", "vinid", "unityads", "ironsrc", "chartboost", "vungle", "criteo", "taboola", "mgid",
        "log", "metric", "measurement", "stat", "telemetry", "beacon", "pixel", "collect", "track", 
        "monitor", "event", "report", "crashlytics", "amplitude", "cdn", "akamai", "cloudfront", "fastly", "urioy"
      ],
      "transformations": [
        "RemoveComments",
        "Compress",
        "Validate"
      ]
    }
  ],
  "transformations": [
    "RemoveComments",
    "Compress",
    "Validate",
    "Deduplicate",
    "TrimLines",
    "InsertFinalNewLine",
    "RemoveEmptyLines"
  ]
}
